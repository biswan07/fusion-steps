rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{videoFile} {
      // Stop-gap until signed URLs from a Cloud Function are wired up.
      // Today VideoUpload stores external URLs (YouTube/Drive) on the
      // videos/{id} Firestore doc rather than uploading to Storage, so this
      // path is unused in practice. When Storage-hosted videos return,
      // students must read via Cloud Function-issued signed URLs — not
      // direct getDownloadURL — so this rule denies all student reads.
      allow read: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
  }
}
